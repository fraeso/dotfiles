# font
font-size = 16
font-feature = -liga, -calt, -dlig
# font-family = CaskaydiaCove Nerd Font
# font-family = Lilex
# font-family = IoskeleyMonoTerm Nerd Font Medium
# font-family = Iosevka Custom
# font-family = UbuntuMono Nerd Font
