# monaspace configs (enable ligature) - krypton is minecraft font
font-family = JetBrainsMono Nerd Font Mono
### monolisa font tweaks
# font-family = MonoLisa Nerd Font Mono
# adjust-cell-height = 20%
###
# font-family = FiraCode Nerd Font Mono
# font-family = Menlo
# font-family = Monaco

cursor-style = block
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background

# background
background-blur-radius = 25
background-opacity = 0.88

# window settings
window-decoration = auto
window-theme = ghostty
window-padding-balance = true
window-padding-x = 5
window-padding-y = 5

# ghostty icon
# macos-icon = official
macos-icon = paper
# macos-icon = blueprint
# macos-icon = holographic
# macos-icon = retro
# macos-icon = glass

# misc
mouse-hide-while-typing = true
bold-is-bright = true
auto-update = download
auto-update-channel = stable
macos-option-as-alt=true
keybind = shift+enter=text:\n
window-theme = "auto"
macos-titlebar-style = tabs
confirm-close-surface = false

# vim-style pane navigation
keybind = cmd+option+h=goto_split:left
keybind = cmd+option+j=goto_split:down
keybind = cmd+option+k=goto_split:up
keybind = cmd+option+l=goto_split:right

# unbind arrow key navigation
keybind = cmd+option+left=unbind
keybind = cmd+option+right=unbind
keybind = cmd+option+up=unbind
keybind = cmd+option+down=unbind

# pane/split settings
unfocused-split-opacity = 0.55
split-divider-color = #524f67
